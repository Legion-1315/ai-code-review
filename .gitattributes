# Enforce LF for shell/CI scripts so Docker builds on Linux even if committed from Windows
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# CRLF for Windows batch
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
